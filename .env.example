# Aeris project-level environment configuration
# Copy this file to `.env`, then fill in the values you actually want to use.
#
# Recommended setup:
# 1. Always set `AERIS_CLAUDE_API_KEY`
# 2. Set `AERIS_CLAUDE_BASE_URL` only if you use a custom / compatible endpoint
# 3. Leave `AERIS_CLAUDE_MODEL` unset if you want to switch models from `/model` inside the CLI

# Required
# Claude / Anthropic-compatible API key used by this project
AERIS_CLAUDE_API_KEY=your_claude_api_key

# Optional
# Base URL for the API endpoint
# Default is the official Anthropic endpoint: https://api.anthropic.com/v1
# Example for custom gateway:
# AERIS_CLAUDE_BASE_URL=https://your-gateway.example.com/v1
AERIS_CLAUDE_BASE_URL=https://api.anthropic.com/v1

# Optional
# Default model for this project
# Leave this line commented out if you prefer selecting the model with `/model` in the CLI
# AERIS_CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional
# Enable or disable automatic project-context injection
# true = on, false = off
AERIS_PROJECT_CONTEXT_ENABLED=true
